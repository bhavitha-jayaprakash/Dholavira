# ============================================================
# DRI & CA Server — Environment Variables
# ============================================================
# Copy this file to .env and update values for your local setup.
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (Mac/Linux)
# ============================================================

# ─── Server ───
PORT=4000
NODE_ENV=development

# ─── PostgreSQL (local install, no Docker) ───
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://dri_user:dri_pass@localhost:5432/dri_db

# ─── CORS ───
# Comma-separated origins allowed to call this API
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Bhashini API (Digital India Translation) ───
# Register at https://bhashini.gov.in/ to get credentials
# Leave blank to use mock/demo mode
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model/getModelsPipeline
BHASHINI_INFERENCE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline
