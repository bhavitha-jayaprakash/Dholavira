{
  "name": "dri-ca-server",
  "version": "1.0.0",
  "description": "DRI & CA — Disaster Resilience Intelligence & Community Awareness Backend API. Provides spatial feasibility checks via PostGIS, explainable AI remediation, Bhashini NMT/TTS translation, community alerts, and seasonal awareness tips.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test:health": "curl -s http://localhost:4000/api/v1/health | node -e \"process.stdin.on('data',d=>console.log(JSON.parse(d)))\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
